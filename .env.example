# ════════════════════════════════════════════════════════════════════════════
# UAEM CRM — cấu hình (.env). Copy file này thành `.env` rồi điền.
# install.sh sẽ TỰ SINH các secret nếu bạn để trống. Đừng commit file .env!
# ════════════════════════════════════════════════════════════════════════════

# ── Image phát hành (do nhà cung cấp công bố) ──────────────────────────────────
# Thay OWNER bằng tài khoản/registry của nhà cung cấp, gắn tag phiên bản cụ thể.
UAEMCRM_IMAGE=ghcr.io/trinhleminhan-vn/uaemcrm:latest

# ── Domain (BẮT BUỘC nếu dùng Caddy auto-HTTPS) ────────────────────────────────
# Trỏ 2 domain này (A record) về IP VPS của bạn TRƯỚC khi chạy.
APP_DOMAIN=crm.yourdomain.com
S3_DOMAIN=files.yourdomain.com
# URL công khai để hiển thị/định danh — phải khớp domain ở trên:
APP_URL=https://crm.yourdomain.com
S3_PUBLIC_URL=https://files.yourdomain.com

# ── Bí mật (để TRỐNG → install.sh tự sinh chuỗi mạnh) ──────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=
DB_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# FB_TOKEN_ENC_KEY tuỳ chọn — nếu trống, hệ thống dùng ENCRYPTION_KEY để mã hoá token.
FB_TOKEN_ENC_KEY=

# ── Database / Storage (mặc định ổn, đổi nếu muốn) ─────────────────────────────
DB_USER=crmuser
DB_NAME=uaemcrm
S3_BUCKET=uaemcrm-attachments

# ── Cổng nội bộ (loopback) — không cần đổi nếu dùng Caddy ──────────────────────
APP_PORT=3000
S3_PORT=9000

# ── Tuỳ chọn ───────────────────────────────────────────────────────────────────
# AUTOMATION_STUB_MODE=true để chạy thử không gọi Zalo thật.
AUTOMATION_STUB_MODE=false
# REDIS_URL=redis://redis:6379

# ── AI (tuỳ chọn) — có thể nhập trong giao diện thay vì ở đây ───────────────────
# AI_DEFAULT_PROVIDER=anthropic
# ANTHROPIC_AUTH_TOKEN=

# ── Google Drive backup (tuỳ chọn) — có thể nhập trong giao diện ────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://crm.yourdomain.com/api/v1/integrations/google-drive/oauth/callback
